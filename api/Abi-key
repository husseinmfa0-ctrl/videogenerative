// ⚠️ Your active Fal.ai API key is fully configured below
const FAL_KEY = "8ebf5b31-4cd9-4d5b-b862-90f20651ef7e:afc1d40204362e90f5c84989a4d1e53c"; 

async function generateVideo() {
    const promptInput = document.getElementById("promptInput").value; // Make sure this matches your input ID
    const generateBtn = document.getElementById("generateBtn");      // Make sure this matches your button ID
    const statusDiv = document.getElementById("status");            // Make sure this matches your status text ID
    const videoBox = document.getElementById("videoBox");
    const videoPlayer = document.getElementById("videoPlayer");

    if (!promptInput.trim()) {
        alert("Please enter a creative prompt!");
        return;
    }

    generateBtn.disabled = true;
    statusDiv.innerText = "🎬 Contacting GPU servers... Rendering premium anime frames (Est. 10-20s)...";
    videoBox.style.display = "none";

    // Auto-appends powerful 2.5D/Anime modifiers to guarantee cinematic results every time
    const optimizedPrompt = promptInput + ", 3d semi-realistic anime style, highly detailed photorealistic faces, dynamic motion, unreal engine 5 render, cinematic sports lighting, masterpiece, 4k";

    try {
        // Sending the request to Fal.ai's high-speed queue system
        const response = await fetch("https://queue.fal.run/fal-ai/fast-svd/text-to-video", {
            method: "POST",
            headers: {
                "Authorization": `Key ${FAL_KEY}`,
                "Content-Type": "application/json"
            },
            body: JSON.stringify({
                prompt: optimizedPrompt,
                image_size: "landscape_16_9",
                num_frames: 25,
                fps: 6
            })
        });

        const data = await response.json();

        if (response.ok && data.video && data.video.url) {
            // If the render completed instantly
            videoPlayer.src = data.video.url;
            videoBox.style.display = "block";
            statusDiv.innerText = "✨ Video Generated Successfully!";
            generateBtn.disabled = false;
        } else if (data.request_id) {
            // Checking the render queue status every 3 seconds
            checkQueueStatus(data.request_id);
        } else {
            statusDiv.innerText = "Generation failed. Please check your Fal.ai balance.";
            generateBtn.disabled = false;
        }
    } catch (error) {
        console.error("API Error:", error);
        statusDiv.innerText = "Connection failed. Please check your API Key settings.";
        generateBtn.disabled = false;
    }
}

// Monitors the GPU render queue until the video file is fully ready
async function checkQueueStatus(requestId) {
    const statusDiv = document.getElementById("status");
    const videoBox = document.getElementById("videoBox");
    const videoPlayer = document.getElementById("videoPlayer");
    const generateBtn = document.getElementById("generateBtn");

    const interval = setInterval(async () => {
        try {
            const checkResponse = await fetch(`https://queue.fal.run/fal-ai/fast-svd/text-to-video/requests/${requestId}`, {
                headers: { "Authorization": `Key ${FAL_KEY}` }
            });
            const checkData = await checkResponse.json();

            if (checkData.status === "COMPLETED") {
                clearInterval(interval);
                videoPlayer.src = checkData.outputs.video.url;
                videoBox.style.display = "block";
                statusDiv.innerText = "✨ Video Generated Successfully!";
                generateBtn.disabled = false;
            } else if (checkData.status === "FAILED") {
                clearInterval(interval);
                statusDiv.innerText = "Generation failed. Try adjusting your prompt.";
                generateBtn.disabled = false;
            } else {
                statusDiv.innerText = `⏳ Rendering video frames... (${checkData.status})`;
            }
        } catch (err) {
            clearInterval(interval);
            statusDiv.innerText = "Error tracking queue.";
            generateBtn.disabled = false;
        }
    }, 3000); // Check every 3 seconds
}
